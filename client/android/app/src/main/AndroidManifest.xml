<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true"
            android:showOnLockScreen="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- ── Custom alarm components ───────────────────────────────────── -->

        <!-- Receives AlarmManager broadcast; shows notification + starts TtsAlarmService -->
        <receiver
            android:name=".AlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.chronos.reminder.ALARM" />
            </intent-filter>
        </receiver>

        <!-- Foreground service: plays ringtone + TTS when alarm fires -->
        <service
            android:name=".TtsAlarmService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- Re-schedules alarms after device reboot -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <!-- HTC / OnePlus quick-boot -->
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>

        <!-- ── Capacitor LocalNotifications overrides ────────────────────── -->
        <!-- Required to set exported=false on API 31+ for Capacitor plugin receivers -->
        <receiver
            android:name="com.capacitorjs.plugins.localnotifications.TimedNotificationPublisher"
            android:exported="false"
            tools:replace="android:exported" />
        <receiver
            android:name="com.capacitorjs.plugins.localnotifications.NotificationDismissReceiver"
            android:exported="false"
            tools:replace="android:exported" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

    <!-- ── Permissions ───────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Show notifications (required on Android 13 / API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Exact alarms: USE_EXACT_ALARM is auto-granted on API 33+ for alarm/reminder apps.
         SCHEDULE_EXACT_ALARM is the fallback for API 31-32 (requires user grant in Settings). -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!-- Required for AlarmManager to wake the CPU -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Foreground service for ringtone + TTS -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Required on API 34+ when foregroundServiceType="mediaPlayback" -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- Full-screen intents to wake the lock screen (required on API 34+) -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Re-schedule alarms after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Exemption from battery optimization so alarms survive on Samsung/Xiaomi/Huawei/OPPO -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

</manifest>
