PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/chronos?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@chronos.app

# External server URL (REQUIRED in production to keep Render alive)
SERVER_URL=https://chronou2.onrender.com
